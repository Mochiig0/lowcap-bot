[Unit]
Description=lowcap-bot GeckoTerminal metric snapshot bounded first-run
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/mochi/projects/lowcap-bot
# Bounded first-run confirmation only. Do not enable this as the always-on unit.
Environment=DATABASE_URL=file:/home/mochi/projects/lowcap-bot/prisma/dev.db
Environment=LOWCAP_GECKOTERMINAL_METRIC_PUMP_ONLY=true
Environment=LOWCAP_GECKOTERMINAL_METRIC_LIMIT=2
Environment=LOWCAP_GECKOTERMINAL_METRIC_MAX_ITERATIONS=2
Environment=LOWCAP_GECKOTERMINAL_METRIC_MIN_GAP_MINUTES=10
Environment=LOWCAP_GECKOTERMINAL_METRIC_INTERVAL_SECONDS=60
Environment=LOWCAP_GECKOTERMINAL_METRIC_START_DELAY_SECONDS=0
Environment=LOWCAP_GECKOTERMINAL_METRIC_SINCE_MINUTES=120
Environment=LOWCAP_GECKOTERMINAL_METRIC_SOURCE=geckoterminal.token_snapshot
ExecStart=/home/mochi/projects/lowcap-bot/scripts/run-geckoterminal-metric-watch.sh
Restart=no

[Install]
WantedBy=default.target
