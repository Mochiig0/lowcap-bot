{
  "name": "lowcap-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "migrate:dev": "prisma migrate dev",
    "import": "tsx src/cli/import.ts",
    "import:mint": "tsx src/cli/importMint.ts",
    "import:mint:file": "tsx src/cli/importMintFile.ts",
    "import:mint:source-file": "tsx src/cli/importMintSourceFile.ts",
    "detect:dexscreener:token-profiles": "tsx src/cli/detectDexscreenerTokenProfiles.ts",
    "detect:geckoterminal:new-pools": "tsx src/cli/detectGeckoterminalNewPools.ts",
    "compare:geckoterminal:dexscreener": "tsx src/cli/compareGeckoterminalDexscreener.ts",
    "import:min": "tsx src/cli/importMin.ts",
    "import:file": "tsx src/cli/importFile.ts",
    "trend:update": "tsx src/cli/updateTrend.ts",
    "token:enrich": "tsx src/cli/tokenEnrich.ts",
    "token:rescore": "tsx src/cli/tokenRescore.ts",
    "token:enrich-rescore:geckoterminal": "tsx src/cli/tokenEnrichRescoreGeckoterminal.ts",
    "context:capture:geckoterminal": "tsx src/cli/contextCaptureGeckoterminal.ts",
    "context:compare:geckoterminal": "node --import tsx src/cli/contextCompareGeckoterminal.ts",
    "context:compare:source-families": "node --import tsx src/cli/contextCompareSourceFamilies.ts",
    "logs:summary:geckoterminal:metaplex": "node ./scripts/summarize-geckoterminal-enrich-metaplex-log.mjs",
    "ops:summary:geckoterminal": "node --import tsx src/cli/geckoterminalOpsSummary.ts",
    "review:queue:geckoterminal": "node --import tsx src/cli/geckoterminalReviewQueue.ts",
    "token:show": "tsx src/cli/tokenShow.ts",
    "token:compare": "tsx src/cli/tokenCompare.ts",
    "metric:add": "tsx src/cli/metricAdd.ts",
    "metric:snapshot:geckoterminal": "tsx src/cli/metricSnapshotGeckoterminal.ts",
    "tokens:report": "tsx src/cli/tokensReport.ts",
    "tokens:compare-report": "tsx src/cli/tokensCompareReport.ts",
    "metric:show": "tsx src/cli/metricShow.ts",
    "metrics:report": "tsx src/cli/metricsReport.ts",
    "smoke": "node --import tsx src/cli/smokeTest.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
